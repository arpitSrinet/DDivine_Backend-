generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────

enum UserRole {
  PARENT
  SCHOOL
  ADMIN
}

enum BookingStatus {
  PENDING
  PENDING_PAYMENT
  GOVERNMENT_PAYMENT_PENDING
  CONFIRMED
  REFUNDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

enum PaymentType {
  STRIPE
  GOVERNMENT
}

enum EventBookingStatus {
  DRAFT
  ATTENDEE_COMPLETED
  CONTACT_COMPLETED
  PAYMENT_SELECTED
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum EventPaymentMethod {
  STRIPE
  TAX_FREE_CHILDCARE
  CARD
}

enum RefundStatus {
  PENDING
  COMPLETED
  FAILED
}

enum MatchStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

enum ServiceKey {
  CURRICULAR
  EXTRA_CURRICULAR
  HOLIDAY_CAMPS
  WRAPAROUND
}

enum OtpType {
  SIGNUP
  PASSWORD_RESET
}

enum CalendarEventType {
  TOURNAMENT
  OPEN_DAY
  CAMP
  SCHOOL_VISIT
  OTHER
}

enum ContactInquiryStatus {
  UNREAD
  READ
  RESOLVED
}

enum LeagueGameRequestStatus {
  SUBMITTED
  APPROVED
  REJECTED
}

enum SchoolApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── User ─────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  firstName    String
  lastName     String
  schoolName   String?
  phone        String?
  emergencyPhone String?
  addressLine1 String?
  addressLine2 String?
  town         String?
  county       String?
  postcode     String?
  avatarUrl    String?
  // School-specific fields
  registrationNumber           String?
  schoolType                   String?
  website                      String?
  schoolLogoFileName           String?
  verificationDocumentFileName String?
  isSchoolApproved             Boolean   @default(false)
  schoolApprovalStatus         SchoolApprovalStatus @default(PENDING)
  schoolApprovedAt             DateTime?
  schoolRejectedAt             DateTime?
  schoolLastReviewedAt         DateTime?
  schoolReviewedByAdminId      String?
  schoolApprovalReason         String?
  isActive                     Boolean   @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  children      Child[]
  bookings      Booking[]
  eventBookings CalendarEventBooking[]
  eventBookingIntents EventBookingIntent[]
  notifications Notification[]

  @@index([email, role])
}

// ─── Child ────────────────────────────────────────────────

model Child {
  id                 String   @id @default(cuid())
  userId             String
  firstName          String
  lastName           String
  dateOfBirth        DateTime
  gender             String
  yearGroup          String   @default("Not specified")
  avatarUrl          String?
  medicalConditions  String?
  emergencyNote      String?
  schoolName         String?
  firstAidPermission String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  emergencyContacts EmergencyContact[]
  bookings          Booking[]
  eventBookings     CalendarEventBooking[]
  eventBookingIntents EventBookingIntent[]
  performances      ChildPerformance[]
  eventBookingIntentItems EventBookingIntentItem[]
  eventBookingItems       CalendarEventBookingItem[]

  @@index([userId])
}

// ─── EmergencyContact ─────────────────────────────────────

model EmergencyContact {
  id           String   @id @default(cuid())
  childId      String
  name         String
  phone        String
  relationship String
  createdAt    DateTime @default(now())

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId])
}

// ─── Service ──────────────────────────────────────────────

model Service {
  id        String     @id @default(cuid())
  key       ServiceKey @unique
  title     String
  summary   String
  imageSrc  String
  imageAlt  String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  sessions Session[]
}

// ─── Session ──────────────────────────────────────────────

model Session {
  id              String   @id @default(cuid())
  serviceId       String
  date            DateTime
  time            String
  location        String
  coachName       String?
  maxCapacity     Int
  currentCapacity Int      @default(0)
  minAgeYears     Int
  maxAgeYears     Int
  price           Decimal  @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  service              Service              @relation(fields: [serviceId], references: [id])
  bookings             Booking[]
  performanceRecords ChildPerformance[]

  @@index([serviceId, date])
  @@index([date, isActive])
}

// ─── Booking ──────────────────────────────────────────────

model Booking {
  id          String        @id @default(cuid())
  userId      String
  childId     String?
  sessionId   String
  status      BookingStatus @default(PENDING)
  paymentType PaymentType   @default(STRIPE)
  paymentStatus PaymentStatus @default(PENDING)
  xeroInvoiceId String?     @unique
  xeroInvoiceStatus String?
  xeroInvoiceSyncedAt DateTime?
  price       Decimal       @db.Decimal(10, 2)
  cancelledAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user    User     @relation(fields: [userId], references: [id])
  child   Child?   @relation(fields: [childId], references: [id])
  session Session  @relation(fields: [sessionId], references: [id])
  payment Payment?

  @@index([userId, status])
  @@index([sessionId])
}

// ─── Payment ──────────────────────────────────────────────

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @unique
  stripePaymentIntentId String        @unique
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("gbp")
  status                PaymentStatus @default(PENDING)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  booking Booking  @relation(fields: [bookingId], references: [id])
  invoice Invoice?
  refunds Refund[]

  @@index([stripePaymentIntentId])
}

// ─── Invoice ──────────────────────────────────────────────

model Invoice {
  id            String   @id @default(cuid())
  paymentId     String   @unique
  pdfUrl        String?
  xeroInvoiceId String?
  createdAt     DateTime @default(now())

  payment Payment @relation(fields: [paymentId], references: [id])
}

model XeroConnection {
  id           String   @id
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  tokenType    String   @default("Bearer")
  scope        String?
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Refund ───────────────────────────────────────────────

model Refund {
  id             String       @id @default(cuid())
  paymentId      String
  stripeRefundId String?      @unique
  amount         Decimal      @db.Decimal(10, 2)
  reason         String
  status         RefundStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id])
}

// ─── Notification ─────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ─── OTP ──────────────────────────────────────────────────

model Otp {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      OtpType
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, type])
}

// ─── League ───────────────────────────────────────────────

model Team {
  id         String   @id @default(cuid())
  name       String
  schoolId   String?
  schoolName String?
  photoId    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  photo       MediaAsset?      @relation("TeamPhoto", fields: [photoId], references: [id], onDelete: SetNull)
  homeMatches Match[]          @relation("HomeTeam")
  awayMatches Match[]          @relation("AwayTeam")
  standing    LeagueStanding?
}

model Match {
  id         String      @id @default(cuid())
  homeTeamId String
  awayTeamId String
  homeScore  Int?
  awayScore  Int?
  date       DateTime
  location   String?
  photoId    String?
  status     MatchStatus @default(SCHEDULED)
  approvedAt DateTime?
  approvedByAdminId String?
  approvedViaLeagueGameRequestId String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  homeTeam Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  photo    MediaAsset? @relation("MatchPhoto", fields: [photoId], references: [id], onDelete: SetNull)

  @@index([status, date])
}

model LeagueStanding {
  id            String   @id @default(cuid())
  teamId        String   @unique
  matchesPlayed Int      @default(0)
  wins          Int      @default(0)
  draws         Int      @default(0)
  losses        Int      @default(0)
  goalsFor      Int      @default(0)
  goalsAgainst  Int      @default(0)
  points        Int      @default(0)
  updatedAt     DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id])
}

// ─── Knowledge ────────────────────────────────────────────

model CaseStudy {
  id        String   @id @default(cuid())
  title     String
  body      String
  tag       String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FreeActivityGroup {
  id          String   @id @default(cuid())
  title       String
  description String
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  downloads FreeActivityDownload[]
}

model FreeActivityDownload {
  id      String @id @default(cuid())
  groupId String
  url     String

  group FreeActivityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model FaqGroup {
  id       String  @id @default(cuid())
  title    String
  order    Int     @default(0)
  isActive Boolean @default(true)

  items FaqItem[]
}

model FaqItem {
  id       String @id @default(cuid())
  groupId  String
  question String
  answer   String
  order    Int    @default(0)

  group FaqGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

// ─── Media (admin library) ────────────────────────────────

model MediaAsset {
  id        String   @id @default(cuid())
  name      String
  url       String
  size      Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  teamsWithPhoto Team[]             @relation("TeamPhoto")
  matchesPhoto   Match[]            @relation("MatchPhoto")
  bannerEvents   CalendarEvent[]
  contentSlots   ContentMediaSlot[]
}

// ─── Public calendar events (marketing site) ─────────────

model CalendarEvent {
  id          String            @id @default(cuid())
  title       String
  description String?
  type        CalendarEventType
  date        DateTime
  time        String
  location    String
  category    String?
  startDate   DateTime?
  endDate     DateTime?
  startTime   String?
  endTime     String?
  minAgeYears     Int?
  maxAgeYears     Int?
  maxCapacity     Int?
  currentCapacity Int               @default(0)
  currency        String            @default("GBP")
  subtotal    Decimal           @default(0) @db.Decimal(10, 2)
  serviceFee  Decimal           @default(0) @db.Decimal(10, 2)
  requirements Json?
  addons      Json?
  isPublic    Boolean           @default(false)
  bannerId    String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  banner   MediaAsset?          @relation(fields: [bannerId], references: [id], onDelete: SetNull)
  bookings CalendarEventBooking[]
  intents  EventBookingIntent[]
  dates    CalendarEventDate[]
  bookingItems CalendarEventBookingItem[]

  @@index([date, isPublic])
}

model CalendarEventBooking {
  id        String   @id @default(cuid())
  eventId   String?
  userId    String
  childId   String?
  notes     String?
  intentId  String?  @unique
  status    BookingStatus @default(CONFIRMED)
  bookingReference String? @unique
  medicalNotes String?
  fullName  String?
  email     String?
  phone     String?
  paymentMethod EventPaymentMethod?
  taxFreeChildcareRef String?
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId String? @unique
  currency  String   @default("GBP")
  subtotal  Decimal  @default(0) @db.Decimal(10, 2)
  addonsTotal Decimal @default(0) @db.Decimal(10, 2)
  discountTotal Decimal @default(0) @db.Decimal(10, 2)
  serviceFee Decimal @default(0) @db.Decimal(10, 2)
  totalPaid Decimal @default(0) @db.Decimal(10, 2)
  receiptUrl String?
  xeroInvoiceId       String?
  xeroInvoiceStatus   String?
  xeroInvoiceSyncedAt DateTime?
  cancelledAt DateTime?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  event  CalendarEvent?      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user   User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  child  Child?              @relation(fields: [childId], references: [id], onDelete: SetNull)
  intent EventBookingIntent? @relation(fields: [intentId], references: [id], onDelete: SetNull)
  items  CalendarEventBookingItem[]

  @@index([eventId])
  @@index([userId, createdAt])
}

model EventBookingIntent {
  id        String             @id @default(cuid())
  eventId    String?
  userId     String
  childId    String?
  status     EventBookingStatus @default(DRAFT)
  currentStep String           @default("attendee")
  expiresAt  DateTime
  medicalNotes String?
  addons     Json?
  fullName   String?
  email      String?
  phone      String?
  paymentMethod EventPaymentMethod?
  paymentProvider String?
  taxFreeChildcareRef String?
  stripeCheckoutSessionId String? @unique
  stripePaymentIntentId String? @unique
  stripeCheckoutUrl String?
  stripeCheckoutFingerprint String?
  currency  String             @default("GBP")
  subtotal  Decimal            @default(0) @db.Decimal(10, 2)
  addonsTotal Decimal          @default(0) @db.Decimal(10, 2)
  discountTotal Decimal        @default(0) @db.Decimal(10, 2)
  serviceFee Decimal           @default(0) @db.Decimal(10, 2)
  total     Decimal            @default(0) @db.Decimal(10, 2)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  event   CalendarEvent?       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  child   Child?               @relation(fields: [childId], references: [id], onDelete: SetNull)
  booking CalendarEventBooking?
  items   EventBookingIntentItem[]

  @@index([userId, createdAt])
  @@index([eventId, expiresAt])
}

// ─── Event dates & slots (v2 multi-booking) ──────────────

model CalendarEventDate {
  id        String   @id @default(cuid())
  eventId   String
  date      DateTime
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event CalendarEvent      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  slots CalendarEventSlot[]
  bookingItems CalendarEventBookingItem[]

  @@unique([eventId, date])
  @@index([eventId])
}

model CalendarEventSlot {
  id          String   @id @default(cuid())
  eventDateId String
  startTime   String
  endTime     String
  capacity    Int
  bookedCount Int      @default(0)
  minAgeYears Int?
  maxAgeYears Int?
  price       Decimal  @default(0) @db.Decimal(10, 2)
  serviceFee  Decimal  @default(0) @db.Decimal(10, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  eventDate    CalendarEventDate          @relation(fields: [eventDateId], references: [id], onDelete: Cascade)
  intentItems  EventBookingIntentItem[]
  bookingItems CalendarEventBookingItem[]

  @@unique([eventDateId, startTime, endTime])
  @@index([eventDateId])
}

model EventBookingIntentItem {
  id              String   @id @default(cuid())
  intentId        String
  slotId          String
  childId         String?
  medicalNotes    String?
  addons          Json?
  lineSubtotal    Decimal  @default(0) @db.Decimal(10, 2)
  lineAddonsTotal Decimal  @default(0) @db.Decimal(10, 2)
  lineServiceFee  Decimal  @default(0) @db.Decimal(10, 2)
  lineTotal       Decimal  @default(0) @db.Decimal(10, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  intent EventBookingIntent @relation(fields: [intentId], references: [id], onDelete: Cascade)
  slot   CalendarEventSlot  @relation(fields: [slotId], references: [id], onDelete: Cascade)
  child  Child?             @relation(fields: [childId], references: [id], onDelete: SetNull)

  @@unique([intentId, slotId, childId])
  @@index([intentId])
  @@index([slotId])
}

model CalendarEventBookingItem {
  id              String   @id @default(cuid())
  bookingId       String
  slotId          String
  eventId         String
  eventDateId     String
  childId         String?
  medicalNotes    String?
  addons          Json?
  lineSubtotal    Decimal  @default(0) @db.Decimal(10, 2)
  lineAddonsTotal Decimal  @default(0) @db.Decimal(10, 2)
  lineServiceFee  Decimal  @default(0) @db.Decimal(10, 2)
  lineTotal       Decimal  @default(0) @db.Decimal(10, 2)
  createdAt       DateTime @default(now())

  booking CalendarEventBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  slot    CalendarEventSlot    @relation(fields: [slotId], references: [id])
  event   CalendarEvent        @relation(fields: [eventId], references: [id], onDelete: Restrict)
  eventDate CalendarEventDate  @relation(fields: [eventDateId], references: [id], onDelete: Restrict)
  child   Child?               @relation(fields: [childId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([slotId])
  @@index([eventId])
  @@index([eventDateId])
}

// ─── Contact form inquiries ───────────────────────────────

model ContactInquiry {
  id          String               @id @default(cuid())
  name        String
  email       String
  phone       String?
  message     String
  status      ContactInquiryStatus @default(UNREAD)
  submittedAt DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([status, submittedAt])
}

model LeagueGameRequest {
  id           String                  @id @default(cuid())
  status       LeagueGameRequestStatus @default(SUBMITTED)
  yearGroup    String
  playingAt    String
  gameDate     DateTime
  gameTime     String
  addressLine1 String
  addressLine2 String?
  town         String
  postCode     String
  ip           String?
  userAgent    String?
  reviewedAt   DateTime?
  reviewedByAdminId String?
  rejectionReason String?
  approvedMatchId String?
  submittedAt  DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([status, submittedAt])
  @@index([gameDate])
}

model SchoolGroupEmailLog {
  id              String   @id @default(cuid())
  subject         String
  message         String
  targetStatus    String
  recipientsCount Int
  sentCount       Int
  sentByAdminId   String
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

// ─── Child performance (admin-only records) ───────────────

model ChildPerformance {
  id               String   @id @default(cuid())
  childId          String
  sessionId        String
  date             DateTime
  goalsScored      Int      @default(0)
  assists          Int      @default(0)
  attendanceRate   Decimal  @db.Decimal(5, 2)
  rating           Int?
  coachNotes       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  child   Child   @relation(fields: [childId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id])

  @@index([childId, date])
  @@index([sessionId])
}

// ─── Site content (CMS) ───────────────────────────────────

model ContentStat {
  key    String @id
  value  String
  suffix String @default("")
  label  String
}

model Testimonial {
  id      String @id @default(cuid())
  quote   String
  speaker String
  role    String
  order   Int    @default(0)
}

model Partner {
  id          String @id @default(cuid())
  name        String
  description String
  type        String
}

model ContentMediaSlot {
  slot    String      @id
  mediaId String?
  media   MediaAsset? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
}
